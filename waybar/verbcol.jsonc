// -*- mode: jsonc -*-
{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 32, // Waybar height (to be removed for auto height)
    "width": 1920, // Waybar width
    "spacing": 3, // Gaps between modules (4px)
       "margin-top": -4,
    "margin-bottom": -4,
    
    "modules-left": [
        "niri/workspaces",
        "niri/window"
        // "custom/spotify"
    ],

    "modules-center": [
        "clock",
         "custom/weather"
    ],
    "modules-right": [
    	"battery",
        "group/cpu",
        "memory",
        "group/hw",
    ],

    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },
    
    "niri/window": {
    "format": " {title:.40}",
    "max-length": 40,
    "tooltip": true,
  "separate-outputs": true
},

    
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": " {:%A, %d %B %H:%M}",
               "format-alt": " {:%H:%M}",
    },
    "cpu": {
        "format": " {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": " {used:0.1f}GiB"
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon6/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}°C {icon}",
        "format": " {temperatureC}°C",
        "format-icons": ["󰉬", "", "󰉪"]
    },
    "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": ["", "", ""],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip": false
},

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}% - {time}",
        "format-full": "{capacity}% {icon}",
        "format-charging":" {capacity}%",
        "format-plugged": " {capacity}%",
        //"format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""],
        "on-click": "kitty -e btop"
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        "max-length": 15,
        // "format-wifi": " {essid} ({signalStrength}%)",
        "format-wifi": "",
        "format-ethernet": "{ipaddr}/{cidr} 󰊗",
        "tooltip-format": "{ifname} via {gwaddr} 󰊗",
        "format-linked": "{ifname} (No IP) 󰊗",
        "format-disconnected": "󱛅",
        "on-click": "~/.local/bin/wifi.sh"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": " {volume}%",
        //"format-bluetooth": "{volume}% {icon} {format_s" , //ource}",
        //"format-bluetooth-muted": "󰅶 {icon} {format_source}",
        "format-muted": "󰅶" , //{format_source}",
        //"format-source": " {volume}%",
        //"format-source-muted": " ",
        "on-click": "pavucontrol"
    },

    "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": " {volume}%",
    "format-source-muted": "",
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%",
    "tooltip-format": "{source_desc} | {source_volume}%"
},

    "custom/weather": {
    "format": "{}°C",
    "tooltip": true,
    "interval": 5400,
    "exec": "wttrbar --nerd --hide-conditions --date-format '%m/%d' --mph --location=Semarang",
    "return-type": "json"
},

       "custom/spotify": {
        "max-length": 30,
	    "exec": "~/.local/bin/spotify.sh",
    "exec-if": "pgrep spotify",
	    "interval": 5,
        "on-click": "playerctl next",
        "on-click-right": "playerctl previous",
	    "on-click-middle": "playerctl -p spotify play-pause",
	    "on-scroll-up": "playerctl -p spotify volume 0.05+",
"on-scroll-down": "playerctl -p spotify volume 0.05-"
	},

        "group/cpu": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "temperature"
        ]
    },

    "group/hw": {
        "orientation": "horizontal",
        "modules": [
            "pulseaudio#microphone",
            "pulseaudio",
            "backlight",
            "network"
        ]
    },
}
